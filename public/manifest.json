{
  "manifest_version": 3,
  "name": "PodcastBoard",
  "version": "0.1.0",
  "description": "Turn podcast scripts and voice-over audio into timestamped presentation slide images.",
  "permissions": ["storage", "sidePanel", "clipboardWrite", "activeTab", "scripting", "downloads"],
  "host_permissions": [
    "https://openrouter.ai/*",
    "https://api.openai.com/*",
    "https://api.groq.com/*",
    "https://ollama.com/*",
    "http://localhost/*",
    "http://127.0.0.1/*",
    "https://chatgpt.com/*"
  ],
  "action": {
    "default_title": "Open PodcastBoard"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "src/sidepanel/index.html"
  },

  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
